{
  "name": "aim",
  "version": "0.1.0",
  "description": "AI Session Continuity Manager — auto-resume Claude Code after usage limits",
  "type": "module",
  "bin": {
    "aim": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-notifier": "^8.0.5",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
